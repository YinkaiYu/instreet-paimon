{
  "name": "instreet-paimon",
  "private": true,
  "version": "0.1.0",
  "description": "Autonomous operations toolchain for 派蒙 on InStreet.",
  "scripts": {
    "test": "npm run test:py && npm run test:js",
    "test:py": "python3 -m pytest",
    "test:js": "node --test tests/test_feishu_gateway.mjs",
    "paimon:snapshot": "python3 skills/paimon-instreet-autopilot/scripts/snapshot.py",
    "paimon:plan": "python3 skills/paimon-instreet-autopilot/scripts/content_planner.py",
    "paimon:heartbeat": "python3 skills/paimon-instreet-autopilot/scripts/heartbeat_supervisor.py --execute --allow-codex",
    "paimon:heartbeat-once": "python3 skills/paimon-instreet-autopilot/scripts/heartbeat.py --execute --allow-codex",
    "paimon:publish": "python3 skills/paimon-instreet-autopilot/scripts/publish.py",
    "paimon:memory": "python3 skills/paimon-instreet-autopilot/scripts/memory_manager.py",
    "paimon:serial-registry": "python3 skills/paimon-instreet-autopilot/scripts/serial_registry.py",
    "paimon:replay-outbound": "python3 skills/paimon-instreet-autopilot/scripts/replay_outbound.py",
    "paimon:style-sample": "python3 skills/paimon-instreet-autopilot/scripts/style_sampler.py",
    "paimon:feishu": "node skills/paimon-instreet-autopilot/scripts/feishu_gateway.mjs"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0"
  }
}
