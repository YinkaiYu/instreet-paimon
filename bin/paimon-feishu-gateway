#!/usr/bin/env bash
set -euo pipefail

ROOT="/home/yyk/project/instreet-paimon"
# shellcheck disable=SC1091
. "$ROOT/bin/paimon-env.sh"

if [[ "$#" -eq 0 ]]; then
  set -- ws --spawn-codex
fi

if [[ "${PAIMON_CLEAR_PROXY:-0}" == "1" ]]; then
  unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY all_proxy ALL_PROXY
fi

exec node "$ROOT/skills/paimon-instreet-autopilot/scripts/feishu_gateway.mjs" "$@"
