#!/usr/bin/env bash
set -euo pipefail

ROOT="/home/yyk/project/instreet-paimon"
PID_FILE="$ROOT/state/current/feishu_gateway.pid"
QUEUE_FILE="$ROOT/state/current/feishu_queue.json"
SESSIONS_FILE="$ROOT/state/current/feishu_sessions.json"
REPORT_TARGET_FILE="$ROOT/state/current/feishu_report_target.json"
CONFIG_FILE="$ROOT/config/paimon.json"
LOG_FILE="$ROOT/logs/feishu-gateway.log"

if [[ -f "$PID_FILE" ]]; then
  PID="$(cat "$PID_FILE" 2>/dev/null || true)"
else
  PID=""
fi

if [[ -n "${PID:-}" ]] && kill -0 "$PID" 2>/dev/null; then
  echo "status=running pid=$PID"
else
  FALLBACK_PID="$(pgrep -f '/home/yyk/project/instreet-paimon/skills/paimon-instreet-autopilot/scripts/feishu_gateway.mjs ws' | head -n 1 || true)"
  if [[ -n "${FALLBACK_PID:-}" ]] && kill -0 "$FALLBACK_PID" 2>/dev/null; then
    echo "status=running pid=$FALLBACK_PID"
  else
    echo "status=stopped"
  fi
fi

if [[ -f "$CONFIG_FILE" ]]; then
  echo "config_file=$CONFIG_FILE"
  python3 - <<'PY'
import json
from pathlib import Path
cfg = json.loads(Path("/home/yyk/project/instreet-paimon/config/paimon.json").read_text())
auto = cfg.get("automation", {})
print(
    "runtime_backend={backend} default_mode={mode} card_callback_enabled={card}".format(
        backend=auto.get("feishu_runtime_backend", "app-server"),
        mode=auto.get("feishu_default_collaboration_mode", "default"),
        card=auto.get("feishu_card_callback_enabled", False),
    )
)
PY
fi

if [[ -f "$SESSIONS_FILE" ]]; then
  echo "sessions_file=$SESSIONS_FILE"
  python3 - <<'PY'
import json
from pathlib import Path
data = json.loads(Path("/home/yyk/project/instreet-paimon/state/current/feishu_sessions.json").read_text())
for chat_id, session in data.get("chats", {}).items():
    print(
        "chat={chat} thread={thread} mode={mode} active_turn={turn} status={status} pending_request={pending}".format(
            chat=chat_id,
            thread=session.get("thread_id", "")[:18],
            mode=session.get("mode", "default"),
            turn=session.get("active_turn_id", "")[:18],
            status=session.get("status", ""),
            pending=session.get("pending_request_id", ""),
        )
    )
PY
fi

if [[ -f "$QUEUE_FILE" ]]; then
  echo "queue_file=$QUEUE_FILE"
  python3 - <<'PY'
import json
from pathlib import Path
queue = json.loads(Path("/home/yyk/project/instreet-paimon/state/current/feishu_queue.json").read_text())
for chat_id, chat in queue.get("chats", {}).items():
    pending = len(chat.get("pending", []))
    processing = 0 if not chat.get("processing") else len(chat["processing"].get("message_ids", []))
    print(f"chat={chat_id} pending={pending} processing={processing}")
PY
fi

if [[ -f "$REPORT_TARGET_FILE" ]]; then
  echo "report_target_file=$REPORT_TARGET_FILE"
  python3 - <<'PY'
import json
from pathlib import Path
target = json.loads(Path("/home/yyk/project/instreet-paimon/state/current/feishu_report_target.json").read_text())
receive_id_type = target.get("receive_id_type", "chat_id")
receive_id = target.get("receive_id", "")
chat_type = target.get("chat_type", "")
source = target.get("source", "")
updated_at = target.get("updated_at", "")
print(f"report_target={receive_id_type}:{receive_id} chat_type={chat_type} source={source} updated_at={updated_at}")
PY
fi

if [[ -f "$LOG_FILE" ]]; then
  echo "log_tail=$LOG_FILE"
  tail -n 10 "$LOG_FILE"
fi
